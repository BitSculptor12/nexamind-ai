# Database (MongoDB Atlas recommended for Railway)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/nexamind

# Server
PORT=5000
NODE_ENV=production

# Optional: separate frontend URL (not needed when API serves the built client)
CLIENT_URL=https://your-app.up.railway.app

# Auth
JWT_SECRET=change_this_to_a_long_random_secret

# AI
OPENROUTER_API_KEY=your_openrouter_api_key

# Payments (optional)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# STRIPE_SECRET_KEY=
